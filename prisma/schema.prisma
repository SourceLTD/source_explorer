generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model frame_roles {
  created_at         DateTime             @default(now())
  updated_at         DateTime             @default(now())
  id                 BigInt               @id @default(autoincrement())
  frame_id           BigInt
  description        String?
  notes              String?
  main               Boolean?
  examples           String[]             @default([])
  label              String?
  fillers            Json?
  frames             frames               @relation(fields: [frame_id], references: [id], onDelete: Cascade)
  role_group_members role_group_members[]

  @@unique([id, frame_id], map: "uq_frame_roles_id_frame")
  @@index([frame_id], map: "idx_frame_roles_frame_id")
}

model frames {
  label                                                           String
  definition                                                      String?
  short_definition                                                String?
  created_at                                                      DateTime               @default(now())
  updated_at                                                      DateTime               @default(now())
  id                                                              BigInt                 @id @default(autoincrement())
  flagged                                                         Boolean?               @default(false)
  flagged_reason                                                  String?
  verifiable                                                      Boolean?               @default(false)
  unverifiable_reason                                             String?
  version                                                         Int                    @default(1)
  embedding                                                       Unsupported("vector")?
  deleted                                                         Boolean                @default(false)
  deleted_at                                                      DateTime?              @db.Timestamp(6)
  deleted_reason                                                  String?
  code                                                            String?
  frame_type                                                      frame_type_enum?
  vendler                                                         String?
  multi_perspective                                               Boolean?
  wikidata_id                                                     String?
  recipe                                                          Json?
  recipe_graph                                                    Json?
  subtype                                                         frame_subtype_enum?
  disable_healthcheck                                             Boolean                @default(false)
  merged_into                                                     BigInt?
  frame_relations_frame_relations_source_idToframes               frame_relations[]      @relation("frame_relations_source_idToframes")
  frame_relations_frame_relations_target_idToframes               frame_relations[]      @relation("frame_relations_target_idToframes")
  frame_role_mappings_frame_role_mappings_child_frame_idToframes  frame_role_mappings[]  @relation("frame_role_mappings_child_frame_idToframes")
  frame_role_mappings_frame_role_mappings_parent_frame_idToframes frame_role_mappings[]  @relation("frame_role_mappings_parent_frame_idToframes")
  frame_roles                                                     frame_roles[]
  frame_sense_frames                                              frame_sense_frames[]
  merged_into_frame                                               frames?                @relation("frames_merged_into", fields: [merged_into], references: [id], onUpdate: NoAction, map: "fk_frames_merged_into")
  merged_from_frames                                              frames[]               @relation("frames_merged_into")
  llm_job_items                                                   llm_job_items[]
  role_groups                                                     role_groups[]

  @@index([label], map: "idx_frames_frame_name")
  @@index([flagged], map: "idx_frames_flagged")
  @@index([embedding], map: "idx_frames_embedding")
  @@index([deleted], map: "idx_frames_deleted")
  @@index([verifiable], map: "idx_frames_verifiable")
  @@index([code], map: "idx_frames_code")
  @@index([recipe_graph], map: "idx_frames_recipe_graph", type: Gin)
}

model instantiation_types {
  label       String  @unique
  wikidata_id String? @unique
  id          BigInt  @id @default(autoincrement())
  code        String  @unique(map: "instantiation_types_code_unique") @db.VarChar
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model role_group_members {
  id            BigInt      @id @default(autoincrement())
  role_group_id BigInt
  role_id       BigInt
  created_at    DateTime    @default(now()) @db.Timestamp(6)
  role_groups   role_groups @relation(fields: [role_group_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_role_group_members_group")
  roles         frame_roles @relation(fields: [role_id], references: [id], onDelete: Cascade, map: "fk_role_group_members_role")

  @@unique([role_group_id, role_id], map: "uq_role_group_member")
  @@index([role_group_id], map: "idx_role_group_members_group")
  @@index([role_id], map: "idx_role_group_members_role")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model role_groups {
  id                   BigInt               @id @default(autoincrement())
  description          String?
  require_at_least_one Boolean              @default(true)
  created_at           DateTime             @default(now()) @db.Timestamp(6)
  updated_at           DateTime             @default(now()) @db.Timestamp(6)
  frame_id             BigInt?
  role_group_members   role_group_members[]
  frames               frames?              @relation(fields: [frame_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([frame_id], map: "idx_role_groups_frame_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model llm_job_items {
  id               BigInt              @id @default(autoincrement())
  job_id           BigInt
  status           llm_job_item_status @default(queued)
  attempt_count    Int                 @default(0)
  provider_task_id String?
  llm_request_id   String?
  request_payload  Json?
  response_payload Json?
  flags            Json?
  flagged          Boolean             @default(false)
  last_error       String?
  input_tokens     Int                 @default(0)
  output_tokens    Int                 @default(0)
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  started_at       DateTime?           @db.Timestamptz(6)
  completed_at     DateTime?           @db.Timestamptz(6)
  updated_at       DateTime            @default(now()) @db.Timestamptz(6)
  frame_id         BigInt?
  has_edits        Boolean?            @default(false)
  lexical_unit_id  BigInt?
  frames           frames?             @relation(fields: [frame_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  llm_jobs         llm_jobs            @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lexical_units    lexical_units?      @relation(fields: [lexical_unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([frame_id], map: "idx_llm_job_items_frame")
  @@index([lexical_unit_id], map: "idx_llm_job_items_lexical_unit")
}

model llm_jobs {
  id              BigInt          @id @default(autoincrement())
  label           String?
  submitted_by    String?
  scope_kind      String?
  scope           Json?
  config          Json?
  provider        String?
  provider_run_id String?
  llm_vendor      String?
  llm_request_id  String?
  status          llm_job_status  @default(queued)
  total_items     Int             @default(0)
  processed_items Int             @default(0)
  succeeded_items Int             @default(0)
  failed_items    Int             @default(0)
  flagged_items   Int             @default(0)
  input_tokens    Int             @default(0)
  output_tokens   Int             @default(0)
  cost_microunits BigInt?
  error           String?
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  started_at      DateTime?       @db.Timestamptz(6)
  completed_at    DateTime?       @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  deleted         Boolean         @default(false)
  submitted_items Int             @default(0)
  unseen_change   Boolean         @default(false)
  job_type        llm_job_type?   @default(flag)
  changesets      changesets[]
  llm_job_items   llm_job_items[]
}

model frame_relations {
  id                                       BigInt              @id @default(autoincrement())
  source_id                                BigInt
  target_id                                BigInt
  type                                     frame_relation_type
  created_at                               DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                               DateTime?           @default(now()) @db.Timestamp(6)
  version                                  Int                 @default(1)
  frames_frame_relations_source_idToframes frames              @relation("frame_relations_source_idToframes", fields: [source_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_frame_relations_source")
  frames_frame_relations_target_idToframes frames              @relation("frame_relations_target_idToframes", fields: [target_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_frame_relations_target")

  @@unique([source_id, type, target_id], map: "uq_frame_relation")
  @@index([source_id], map: "idx_frame_relations_source")
  @@index([source_id, type], map: "idx_frame_relations_source_type")
  @@index([target_id], map: "idx_frame_relations_target")
  @@index([target_id, type], map: "idx_frame_relations_target_type")
  @@index([type], map: "idx_frame_relations_type")
}

model frame_role_mappings {
  id                                                 BigInt   @id @default(autoincrement())
  parent_frame_id                                    BigInt
  child_frame_id                                     BigInt
  parent_role_label                                  String
  child_role_label                                   String?
  is_absorbed                                        Boolean?
  incorporated_value                                 String?
  model                                              String?
  run_id                                             String   @default("")
  created_at                                         DateTime @default(now()) @db.Timestamptz(6)
  frames_frame_role_mappings_child_frame_idToframes  frames   @relation("frame_role_mappings_child_frame_idToframes", fields: [child_frame_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  frames_frame_role_mappings_parent_frame_idToframes frames   @relation("frame_role_mappings_parent_frame_idToframes", fields: [parent_frame_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([parent_frame_id, child_frame_id, parent_role_label, child_role_label, run_id], map: "frame_role_mappings_edge_role_run_uq")
  @@index([parent_frame_id], map: "frame_role_mappings_parent_frame_idx")
  @@index([child_frame_id], map: "frame_role_mappings_child_frame_idx")
}

model audit_log {
  id           BigInt           @id @default(autoincrement())
  entity_type  entity_type
  entity_id    BigInt
  field_name   String
  operation    change_operation
  old_value    Json?
  new_value    Json?
  changed_by   String
  changed_at   DateTime         @default(now()) @db.Timestamptz(6)
  changeset_id BigInt?
  changesets   changesets?      @relation(fields: [changeset_id], references: [id], onUpdate: NoAction)

  @@index([changed_at], map: "idx_audit_log_changed_at")
  @@index([changed_by], map: "idx_audit_log_changed_by")
  @@index([entity_type, entity_id], map: "idx_audit_log_entity")
}

/// Append-only row history populated by database triggers.
/// Do NOT create/update/delete rows from application code; writes are owned
/// by the `log_entity_row_history()` trigger function. See
/// migrations/add_row_history.sql.
model entity_row_history {
  id           BigInt           @id @default(autoincrement())
  table_name   String
  entity_type  entity_type?
  entity_id    BigInt?
  entity_key   Json?
  operation    change_operation
  changed_at   DateTime         @default(dbgenerated("clock_timestamp()")) @db.Timestamptz(6)
  changed_by   String?
  changeset_id BigInt?
  old_row      Json?
  new_row      Json?

  @@index([table_name, entity_id, changed_at(sort: Desc)], map: "idx_entity_row_history_table_entity_time")
  @@index([entity_type, entity_id, changed_at(sort: Desc)], map: "idx_entity_row_history_type_entity_time")
  @@index([changed_at(sort: Desc)], map: "idx_entity_row_history_changed_at")
  @@index([changeset_id], map: "idx_entity_row_history_changeset")
  @@index([changed_by], map: "idx_entity_row_history_changed_by")
  @@index([entity_key], map: "idx_entity_row_history_entity_key", type: Gin)
}

model changesets {
  id                    BigInt                         @id @default(autoincrement())
  entity_type           entity_type
  entity_id             BigInt?
  operation             change_operation
  entity_version        Int?
  before_snapshot       Json?
  after_snapshot        Json?
  status                changeset_status               @default(pending)
  created_by            String
  created_at            DateTime                       @default(now()) @db.Timestamptz(6)
  reviewed_by           String?
  reviewed_at           DateTime?                      @db.Timestamptz(6)
  committed_at          DateTime?                      @db.Timestamptz(6)
  llm_job_id            BigInt?
  issue_id              BigInt?
  /// v2: when set, this changeset is part of an N>=2 atomic plan. v1
  /// single-entity remediation strategies leave this NULL; v2 structural
  /// strategies (split_frame, merge_frame, move_frame_sense, etc.) populate
  /// it so the commit endpoint can apply every member in one transaction.
  change_plan_id        BigInt?
  ai_revisions          ai_revisions[]
  audit_log             audit_log[]
  change_comments       change_comments[]
  change_plan           change_plans?                  @relation(fields: [change_plan_id], references: [id], onUpdate: NoAction, map: "fk_changesets_change_plan")
  issues                issues?                        @relation(fields: [issue_id], references: [id], onUpdate: NoAction, map: "fk_changesets_issue")
  llm_jobs              llm_jobs?                      @relation(fields: [llm_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_changesets_llm_job")
  comment_reads         comment_reads[]
  field_changes         field_changes[]
  health_check_findings health_check_findings[]
  remediation_proposals health_remediation_proposals[] @relation("ChangesetRemediationProposals")

  @@index([created_at], map: "idx_changesets_created_at")
  @@index([created_by], map: "idx_changesets_created_by")
  @@index([entity_type, entity_id], map: "idx_changesets_entity")
  @@index([status], map: "idx_changesets_status")
  @@index([llm_job_id], map: "idx_changesets_llm_job")
  @@index([issue_id], map: "idx_changesets_issue")
}

model change_plans {
  id                    BigInt                         @id @default(autoincrement())
  /// Free-form strategy / kind tag mirroring `health_diagnosis_codes.remediation_strategy`.
  /// The UI selects a per-kind renderer (split, merge, move, attach, composite) on this value.
  plan_kind             String
  /// Optional one-line summary for list views.
  summary               String?
  issue_id              BigInt?
  created_by            String
  status                change_plan_status             @default(pending)
  reviewed_by           String?
  reviewed_at           DateTime?                      @db.Timestamptz(6)
  committed_at          DateTime?                      @db.Timestamptz(6)
  /// Populated by `commitPlan` when an attempt is rejected; consumed by the UI
  /// to surface "X conflicts with Y" messages without a follow-up round trip.
  conflict_report       Json?
  metadata              Json                           @default("{}")
  created_at            DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                       @default(now()) @updatedAt @db.Timestamptz(6)
  issue                 issues?                        @relation(fields: [issue_id], references: [id], onUpdate: NoAction, map: "fk_change_plans_issue")
  changesets            changesets[]
  remediation_proposals health_remediation_proposals[] @relation("ChangePlanRemediationProposals")

  @@index([status], map: "idx_change_plans_status")
  @@index([created_by], map: "idx_change_plans_created_by")
  @@index([issue_id], map: "idx_change_plans_issue")
  @@index([plan_kind], map: "idx_change_plans_kind")
}

model issues {
  id                           BigInt                          @id @default(autoincrement())
  title                        String
  description                  String?
  status                       issue_status                    @default(open)
  priority                     issue_priority                  @default(medium)
  labels                       String[]                        @default([])
  created_by                   String
  assignee                     String?
  created_at                   DateTime                        @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime                        @default(now()) @updatedAt @db.Timestamptz(6)
  closed_at                    DateTime?                       @db.Timestamptz(6)
  diagnosis_code_id            BigInt?
  /// When set, the most recent remediation proposal for this issue was rejected
  /// by a human reviewer. The runner refuses to auto-propose again until this is
  /// cleared (e.g. via the issue PATCH endpoint exposed in the UI as
  /// "Allow remediation again").
  remediation_rejected_at      DateTime?                       @db.Timestamptz(6)
  strategy_override            String?
  change_plans                 change_plans[]
  changesets                   changesets[]
  health_check_findings        health_check_findings[]
  remediation_issue_locks      health_remediation_issue_locks?
  health_remediation_proposals health_remediation_proposals[]
  remediation_targets          health_remediation_targets[]
  issue_comments               issue_comments[]
  issue_events                 issue_events[]
  diagnosis_code               health_diagnosis_codes?         @relation(fields: [diagnosis_code_id], references: [id], onUpdate: NoAction, map: "fk_issues_diagnosis_code")

  @@index([status], map: "idx_issues_status")
  @@index([priority], map: "idx_issues_priority")
  @@index([assignee], map: "idx_issues_assignee")
  @@index([created_by], map: "idx_issues_created_by")
  @@index([created_at], map: "idx_issues_created_at")
  @@index([diagnosis_code_id], map: "idx_issues_diagnosis_code")
}

model issue_comments {
  id         BigInt    @id @default(autoincrement())
  issue_id   BigInt
  author     String
  content    String
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  edited     Boolean   @default(false)
  deleted    Boolean   @default(false)
  deleted_at DateTime? @db.Timestamptz(6)
  issues     issues    @relation(fields: [issue_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_issue_comments_issue")

  @@index([issue_id], map: "idx_issue_comments_issue")
  @@index([created_at], map: "idx_issue_comments_created_at")
}

model issue_events {
  id         BigInt           @id @default(autoincrement())
  issue_id   BigInt
  actor      String
  event_type issue_event_type
  metadata   Json?
  created_at DateTime         @default(now()) @db.Timestamptz(6)
  issues     issues           @relation(fields: [issue_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_issue_events_issue")

  @@index([issue_id], map: "idx_issue_events_issue")
  @@index([created_at], map: "idx_issue_events_created_at")
  @@index([event_type], map: "idx_issue_events_type")
}

model health_check_definitions {
  id                      BigInt                    @id @default(autoincrement())
  code                    String                    @unique
  label                   String
  description             String?
  target_types            entity_type[]             @default([])
  rule_version            Int                       @default(1)
  enabled                 Boolean                   @default(true)
  config                  Json?
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  /// How runs of this check are executed. Either an LLM batch job
  /// (`llm_batch`, the default) or an in-process programmatic worker
  /// (`programmatic`). DB-level CHECK constraint enforces values.
  execution_kind          String                    @default("llm_batch")
  health_check_batch_jobs health_check_batch_jobs[]
  results                 health_check_results[]
  runs                    health_check_runs[]
  states                  health_check_state[]
  diagnosis_codes         health_diagnosis_codes[]

  @@index([enabled], map: "idx_health_check_definitions_enabled")
}

model health_diagnosis_codes {
  id                           BigInt                        @id @default(autoincrement())
  check_definition_id          BigInt?
  code                         String                        @unique
  label                        String
  description                  String?
  examples                     String[]                      @default([])
  severity                     issue_priority                @default(medium)
  category                     String?
  enabled                      Boolean                       @default(true)
  created_at                   DateTime                      @default(now()) @db.Timestamptz(6)
  applies_to_frame_types       frame_type_enum[]             @default([])
  applies_to_frame_subtypes    frame_subtype_enum[]          @default([])
  match_null_subtype           Boolean                       @default(false)
  group_id                     BigInt?
  /// Stable machine key describing the intended remediation category.
  /// Uses DB-entity language, e.g. `update_frame_role_description`.
  remediation_strategy         String?
  /// Optional human guidance for local nuance. Not executable by itself.
  remediation_notes            String?
  quick_summary                String?
  findings                     health_check_findings[]
  health_check_definition      health_check_definitions?     @relation(fields: [check_definition_id], references: [id], onUpdate: NoAction, map: "fk_health_diagnosis_codes_check")
  health_diagnosis_code_groups health_diagnosis_code_groups? @relation(fields: [group_id], references: [id], onUpdate: NoAction)
  remediation_targets          health_remediation_targets[]
  issues                       issues[]

  @@index([check_definition_id], map: "idx_health_diagnosis_codes_check")
  @@index([severity], map: "idx_health_diagnosis_codes_severity")
  @@index([applies_to_frame_types], map: "idx_health_diagnosis_codes_frame_types", type: Gin)
  @@index([applies_to_frame_subtypes], map: "idx_health_diagnosis_codes_frame_subtypes", type: Gin)
  @@index([group_id], map: "idx_health_diagnosis_codes_group_id")
  @@index([remediation_strategy], map: "idx_health_diagnosis_codes_remediation_strategy")
}

model health_check_runs {
  id                      BigInt                         @id @default(autoincrement())
  check_definition_id     BigInt?
  label                   String?
  status                  health_check_run_status        @default(queued)
  scope                   Json?
  config                  Json?
  worker_id               String?
  model                   String?
  llm_job_id              BigInt?
  total_items             Int                            @default(0)
  processed_items         Int                            @default(0)
  passed_items            Int                            @default(0)
  warning_items           Int                            @default(0)
  failed_items            Int                            @default(0)
  error_items             Int                            @default(0)
  input_tokens            Int                            @default(0)
  output_tokens           Int                            @default(0)
  cost_microunits         BigInt?
  error                   String?
  created_at              DateTime                       @default(now()) @db.Timestamptz(6)
  started_at              DateTime?                      @db.Timestamptz(6)
  completed_at            DateTime?                      @db.Timestamptz(6)
  updated_at              DateTime                       @default(now()) @updatedAt @db.Timestamptz(6)
  health_check_batch_jobs health_check_batch_jobs[]
  results                 health_check_results[]
  issue_sweep             health_check_run_issue_sweeps?
  check_definition        health_check_definitions?      @relation(fields: [check_definition_id], references: [id], onUpdate: NoAction, map: "fk_health_check_runs_check")

  @@index([check_definition_id], map: "idx_health_check_runs_check")
  @@index([status], map: "idx_health_check_runs_status")
  @@index([created_at], map: "idx_health_check_runs_created_at")
}

model health_check_results {
  id                  BigInt                     @id @default(autoincrement())
  run_id              BigInt
  check_definition_id BigInt
  entity_type         entity_type
  entity_id           BigInt
  entity_key          Json?
  status              health_check_result_status
  summary             String?
  reasoning           String?
  confidence          Decimal?                   @db.Decimal(3, 2)
  target_version      Int?
  target_fingerprint  String?
  request_payload     Json?
  response_payload    Json?
  metadata            Json?
  error               String?
  checked_at          DateTime                   @default(now()) @db.Timestamptz(6)
  findings            health_check_findings[]
  check_definition    health_check_definitions   @relation(fields: [check_definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_health_check_results_check")
  run                 health_check_runs          @relation(fields: [run_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_health_check_results_run")

  @@index([run_id], map: "idx_health_check_results_run")
  @@index([check_definition_id], map: "idx_health_check_results_check")
  @@index([entity_type, entity_id], map: "idx_health_check_results_entity")
  @@index([status], map: "idx_health_check_results_status")
  @@index([checked_at], map: "idx_health_check_results_checked_at")
}

model health_check_state {
  id                  BigInt                      @id @default(autoincrement())
  check_definition_id BigInt
  entity_type         entity_type
  entity_id           BigInt
  entity_key_hash     String                      @default("")
  entity_key          Json?
  last_result_id      BigInt?
  last_status         health_check_result_status?
  last_checked_at     DateTime?                   @db.Timestamptz(6)
