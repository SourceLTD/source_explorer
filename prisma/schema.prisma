generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model instantiation_types {
  label       String  @unique
  wikidata_id String? @unique
  id          BigInt  @id @default(autoincrement())
  code        String  @unique(map: "instantiation_types_code_unique") @db.VarChar
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model llm_job_items {
  id               BigInt              @id @default(autoincrement())
  job_id           BigInt
  status           llm_job_item_status @default(queued)
  attempt_count    Int                 @default(0)
  provider_task_id String?
  llm_request_id   String?
  request_payload  Json?
  response_payload Json?
  flags            Json?
  flagged          Boolean             @default(false)
  last_error       String?
  input_tokens     Int                 @default(0)
  output_tokens    Int                 @default(0)
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  started_at       DateTime?           @db.Timestamptz(6)
  completed_at     DateTime?           @db.Timestamptz(6)
  updated_at       DateTime            @default(now()) @db.Timestamptz(6)
  concept_id       BigInt?
  has_edits        Boolean?            @default(false)
  lexical_unit_id  BigInt?
  concepts         concepts?           @relation(fields: [concept_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  llm_jobs         llm_jobs            @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lexical_units    lexical_units?      @relation(fields: [lexical_unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lexical_unit_id], map: "idx_llm_job_items_lexical_unit")
  @@index([concept_id], map: "idx_llm_job_items_concept")
}

model llm_jobs {
  id              BigInt          @id @default(autoincrement())
  label           String?
  submitted_by    String?
  scope_kind      String?
  scope           Json?
  config          Json?
  provider        String?
  provider_run_id String?
  llm_vendor      String?
  llm_request_id  String?
  status          llm_job_status  @default(queued)
  total_items     Int             @default(0)
  processed_items Int             @default(0)
  succeeded_items Int             @default(0)
  failed_items    Int             @default(0)
  flagged_items   Int             @default(0)
  input_tokens    Int             @default(0)
  output_tokens   Int             @default(0)
  cost_microunits BigInt?
  error           String?
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  started_at      DateTime?       @db.Timestamptz(6)
  completed_at    DateTime?       @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  deleted         Boolean         @default(false)
  submitted_items Int             @default(0)
  unseen_change   Boolean         @default(false)
  job_type        llm_job_type?   @default(flag)
  changesets      changesets[]
  llm_job_items   llm_job_items[]
}

model audit_log {
  id           BigInt           @id @default(autoincrement())
  entity_type  entity_type
  entity_id    BigInt
  field_name   String
  operation    change_operation
  old_value    Json?
  new_value    Json?
  changed_by   String
  changed_at   DateTime         @default(now()) @db.Timestamptz(6)
  changeset_id BigInt?
  changesets   changesets?      @relation(fields: [changeset_id], references: [id], onUpdate: NoAction)

  @@index([changed_at], map: "idx_audit_log_changed_at")
  @@index([changed_by], map: "idx_audit_log_changed_by")
  @@index([entity_type, entity_id], map: "idx_audit_log_entity")
}

/// Append-only row history populated by database triggers.
/// Do NOT create/update/delete rows from application code; writes are owned
/// by the `log_entity_row_history()` trigger function. See
/// migrations/add_row_history.sql.
model entity_row_history {
  id           BigInt           @id @default(autoincrement())
  table_name   String
  entity_type  entity_type?
  entity_id    BigInt?
  entity_key   Json?
  operation    change_operation
  changed_at   DateTime         @default(dbgenerated("clock_timestamp()")) @db.Timestamptz(6)
  changed_by   String?
  changeset_id BigInt?
  old_row      Json?
  new_row      Json?

  @@index([table_name, entity_id, changed_at(sort: Desc)], map: "idx_entity_row_history_table_entity_time")
  @@index([entity_type, entity_id, changed_at(sort: Desc)], map: "idx_entity_row_history_type_entity_time")
  @@index([changed_at(sort: Desc)], map: "idx_entity_row_history_changed_at")
  @@index([changeset_id], map: "idx_entity_row_history_changeset")
  @@index([changed_by], map: "idx_entity_row_history_changed_by")
  @@index([entity_key], map: "idx_entity_row_history_entity_key", type: Gin)
}

model changesets {
  id                    BigInt                         @id @default(autoincrement())
  entity_type           entity_type
  entity_id             BigInt?
  operation             change_operation
  entity_version        Int?
  before_snapshot       Json?
  after_snapshot        Json?
  status                changeset_status               @default(pending)
  created_by            String
  created_at            DateTime                       @default(now()) @db.Timestamptz(6)
  reviewed_by           String?
  reviewed_at           DateTime?                      @db.Timestamptz(6)
  committed_at          DateTime?                      @db.Timestamptz(6)
  llm_job_id            BigInt?
  /// v2: when set, this changeset is part of an N>=2 atomic plan. v1
  /// single-entity remediation strategies leave this NULL; v2 structural
  /// strategies (split_frame, merge_frame, move_frame_sense, etc.) populate
  /// it so the commit endpoint can apply every member in one transaction.
  change_plan_id        BigInt?
  /// Revision chain: points to the changeset this revision was derived from.
  revision_parent_id    BigInt?
  /// Monotonically increasing revision number within a chain (1 = original).
  revision_number       Int                            @default(1)
  /// The user's natural language feedback that triggered this revision.
  revision_prompt       String?
  /// Points to the next revision that supersedes this changeset.
  superseded_by_id      BigInt?
  /// Health check finding that triggered this changeset (set for AI-remediated changesets).
  finding_id            BigInt?
  /// Alternatives: the logical change group this changeset is a candidate of.
  /// Multiple changesets sharing one group are coexisting alternatives; a
  /// reviewer selects one and commits it (siblings auto-discarded).
  alternative_group_id  BigInt?
  /// Who/what produced this alternative: 'remediation' (runner), 'revision'
  /// (UI revise), or 'manual' (direct edit). Defaults to 'manual'.
  origin                String                         @default("manual")
  ai_revisions          ai_revisions[]
  audit_log             audit_log[]
  selected_in_group     change_alternatives[]          @relation("AlternativeGroupSelection")
  change_comments       change_comments[]
  alternative_group     change_alternatives?           @relation("AlternativeGroupMembers", fields: [alternative_group_id], references: [id], onUpdate: NoAction, map: "fk_changesets_alternative_group")
  change_plan           change_plans?                  @relation(fields: [change_plan_id], references: [id], onUpdate: NoAction, map: "fk_changesets_change_plan")
  llm_jobs              llm_jobs?                      @relation(fields: [llm_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_changesets_llm_job")
  revision_parent       changesets?                    @relation("ChangesetRevisionChain", fields: [revision_parent_id], references: [id], onUpdate: NoAction, map: "fk_changesets_revision_parent")
  revision_children     changesets[]                   @relation("ChangesetRevisionChain")
  superseded_by         changesets?                    @relation("ChangesetSupersession", fields: [superseded_by_id], references: [id], onUpdate: NoAction, map: "fk_changesets_superseded_by")
  supersedes            changesets[]                   @relation("ChangesetSupersession")
  comment_reads         comment_reads[]
  field_changes         field_changes[]
  health_check_findings health_check_findings[]
  remediation_proposals health_remediation_proposals[] @relation("ChangesetRemediationProposals")

  @@index([created_at], map: "idx_changesets_created_at")
  @@index([created_by], map: "idx_changesets_created_by")
  @@index([entity_type, entity_id], map: "idx_changesets_entity")
  @@index([status], map: "idx_changesets_status")
  @@index([llm_job_id], map: "idx_changesets_llm_job")
}

/// A logical "change": owns N coexisting candidate changesets ("alternatives").
/// Populated by both UI revision (source-explorer) and automated remediation
/// (source-health-check-runner). A reviewer selects one alternative
/// (`selected_changeset_id`) and commits it; non-selected siblings are
/// discarded at commit time.
model change_alternatives {
  id                    BigInt           @id @default(autoincrement())
  /// Entity this change targets. NULL for plan-scoped groups.
  entity_type           entity_type?
  entity_id             BigInt?
  /// Set for plan-scoped alternative groups (alternatives are whole plans).
  change_plan_id        BigInt?
  /// Health check finding that triggered this change (when remediation-sourced).
  finding_id            BigInt?
  status                changeset_status @default(pending)
  /// The alternative the reviewer has selected as the winner (NULL until chosen).
  /// Used for changeset-scoped groups (loose alternatives).
  selected_changeset_id BigInt?
  created_by            String
  created_at            DateTime         @default(now()) @db.Timestamptz(6)
  updated_at            DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  /// The selected winning plan for plan-scoped groups (NULL until chosen, and
  /// NULL for changeset-scoped groups which use `selected_changeset_id`).
  selected_plan_id      BigInt?
  selected_changeset    changesets?      @relation("AlternativeGroupSelection", fields: [selected_changeset_id], references: [id], onUpdate: NoAction, map: "fk_change_alternatives_selected")
  selected_plan         change_plans?    @relation("PlanAlternativeGroupSelection", fields: [selected_plan_id], references: [id], onUpdate: NoAction, map: "fk_change_alternatives_selected_plan")
  plans                 change_plans[]   @relation("PlanAlternativeGroupMembers")
  alternatives          changesets[]     @relation("AlternativeGroupMembers")

  @@index([entity_type, entity_id], map: "idx_change_alternatives_entity")
  @@index([status], map: "idx_change_alternatives_status")
}

model change_plans {
  id                    BigInt                         @id @default(autoincrement())
  /// Free-form strategy / kind tag mirroring `health_diagnosis_codes.remediation_strategy`.
  /// The UI selects a per-kind renderer (split, merge, move, attach, composite) on this value.
  plan_kind             String
  /// Optional one-line summary for list views.
  summary               String?
  created_by            String
  status                change_plan_status             @default(pending)
  reviewed_by           String?
  reviewed_at           DateTime?                      @db.Timestamptz(6)
  committed_at          DateTime?                      @db.Timestamptz(6)
  /// Populated by `commitPlan` when an attempt is rejected; consumed by the UI
  /// to surface "X conflicts with Y" messages without a follow-up round trip.
  conflict_report       Json?
  metadata              Json                           @default("{}")
  created_at            DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                       @default(now()) @updatedAt @db.Timestamptz(6)
  /// Health check finding that triggered this plan (set for AI-remediated plans).
  finding_id            BigInt?
  /// Alternatives: the logical change group this plan is an alternative of.
  /// Multiple plans sharing one group are coexisting alternatives; a reviewer
  /// selects one (`change_alternatives.selected_plan_id`) and commits it
  /// (sibling plans + their changesets auto-discarded).
  alternative_group_id  BigInt?
  selected_in_group     change_alternatives[]          @relation("PlanAlternativeGroupSelection")
  alternative_group     change_alternatives?           @relation("PlanAlternativeGroupMembers", fields: [alternative_group_id], references: [id], onUpdate: NoAction, map: "fk_change_plans_alternative_group")
  changesets            changesets[]
  remediation_proposals health_remediation_proposals[] @relation("ChangePlanRemediationProposals")

  @@index([status], map: "idx_change_plans_status")
  @@index([created_by], map: "idx_change_plans_created_by")
  @@index([plan_kind], map: "idx_change_plans_kind")
}

model health_check_definitions {
  id                      BigInt                    @id @default(autoincrement())
  code                    String                    @unique
  label                   String
  description             String?
  target_types            entity_type[]             @default([])
  rule_version            Int                       @default(1)
  enabled                 Boolean                   @default(true)
  config                  Json?
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  /// How runs of this check are executed. Either an LLM batch job
  /// (`llm_batch`, the default) or an in-process programmatic worker
  /// (`programmatic`). DB-level CHECK constraint enforces values.
  execution_kind          String                    @default("llm_batch")
  health_check_batch_jobs health_check_batch_jobs[]
  results                 health_check_results[]
  runs                    health_check_runs[]
  states                  health_check_state[]
  diagnosis_codes         health_diagnosis_codes[]

  @@index([enabled], map: "idx_health_check_definitions_enabled")
}

model health_diagnosis_codes {
  id                           BigInt                        @id @default(autoincrement())
  check_definition_id          BigInt?
  code                         String                        @unique
  label                        String
  description                  String?
  examples                     String[]                      @default([])
  severity                     issue_priority                @default(medium)
  category                     String?
  enabled                      Boolean                       @default(true)
  created_at                   DateTime                      @default(now()) @db.Timestamptz(6)
  applies_to_archetypes        concept_archetype_enum[]      @default([])
  applies_to_subtypes          concept_subtype_enum[]        @default([])
  match_null_subtype           Boolean                       @default(false)
  group_id                     BigInt?
  /// Stable machine key describing the intended remediation category.
  /// Uses DB-entity language, e.g. `update_frame_role_description`.
  remediation_strategy         String?
  /// Optional human guidance for local nuance. Not executable by itself.
  remediation_notes            String?
  quick_summary                String?
  findings                     health_check_findings[]
  health_check_definition      health_check_definitions?     @relation(fields: [check_definition_id], references: [id], onUpdate: NoAction, map: "fk_health_diagnosis_codes_check")
  health_diagnosis_code_groups health_diagnosis_code_groups? @relation(fields: [group_id], references: [id], onUpdate: NoAction)
  remediation_targets          health_remediation_targets[]

  @@index([check_definition_id], map: "idx_health_diagnosis_codes_check")
  @@index([severity], map: "idx_health_diagnosis_codes_severity")
  @@index([group_id], map: "idx_health_diagnosis_codes_group_id")
  @@index([remediation_strategy], map: "idx_health_diagnosis_codes_remediation_strategy")
  @@index([applies_to_archetypes], map: "idx_health_diagnosis_codes_archetypes", type: Gin)
  @@index([applies_to_subtypes], map: "idx_health_diagnosis_codes_subtypes", type: Gin)
}

model health_check_runs {
  id                      BigInt                    @id @default(autoincrement())
  check_definition_id     BigInt?
  label                   String?
  status                  health_check_run_status   @default(queued)
  scope                   Json?
  config                  Json?
  worker_id               String?
  model                   String?
  llm_job_id              BigInt?
  total_items             Int                       @default(0)
  processed_items         Int                       @default(0)
  passed_items            Int                       @default(0)
  warning_items           Int                       @default(0)
  failed_items            Int                       @default(0)
  error_items             Int                       @default(0)
  input_tokens            Int                       @default(0)
  output_tokens           Int                       @default(0)
  cost_microunits         BigInt?
  error                   String?
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  started_at              DateTime?                 @db.Timestamptz(6)
  completed_at            DateTime?                 @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  health_check_batch_jobs health_check_batch_jobs[]
  results                 health_check_results[]
  check_definition        health_check_definitions? @relation(fields: [check_definition_id], references: [id], onUpdate: NoAction, map: "fk_health_check_runs_check")

  @@index([check_definition_id], map: "idx_health_check_runs_check")
  @@index([status], map: "idx_health_check_runs_status")
  @@index([created_at], map: "idx_health_check_runs_created_at")
}

model health_check_results {
  id                  BigInt                     @id @default(autoincrement())
  run_id              BigInt
  check_definition_id BigInt
  entity_type         entity_type
  entity_id           BigInt
  entity_key          Json?
  status              health_check_result_status
  summary             String?
  reasoning           String?
  confidence          Decimal?                   @db.Decimal(3, 2)
  target_version      Int?
  target_fingerprint  String?
  request_payload     Json?
  response_payload    Json?
  metadata            Json?
  error               String?
  checked_at          DateTime                   @default(now()) @db.Timestamptz(6)
  findings            health_check_findings[]
  check_definition    health_check_definitions   @relation(fields: [check_definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_health_check_results_check")
  run                 health_check_runs          @relation(fields: [run_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_health_check_results_run")

  @@index([run_id], map: "idx_health_check_results_run")
  @@index([check_definition_id], map: "idx_health_check_results_check")
  @@index([entity_type, entity_id], map: "idx_health_check_results_entity")
  @@index([status], map: "idx_health_check_results_status")
  @@index([checked_at], map: "idx_health_check_results_checked_at")
}

model health_check_state {
  id                  BigInt                      @id @default(autoincrement())
  check_definition_id BigInt
  entity_type         entity_type
  entity_id           BigInt
  entity_key_hash     String                      @default("")
  entity_key          Json?
  last_result_id      BigInt?
  last_status         health_check_result_status?
  last_checked_at     DateTime?                   @db.Timestamptz(6)
  target_version      Int?
  target_fingerprint  String?
  open_findings_count Int                         @default(0)
  stale               Boolean                     @default(false)
  next_check_at       DateTime?                   @db.Timestamptz(6)
  updated_at          DateTime                    @default(now()) @updatedAt @db.Timestamptz(6)
  check_definition    health_check_definitions    @relation(fields: [check_definition_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_health_check_state_check")

  @@unique([check_definition_id, entity_type, entity_id, entity_key_hash], map: "uq_health_check_state_target")
  @@index([entity_type, entity_id], map: "idx_health_check_state_entity")
  @@index([last_status], map: "idx_health_check_state_status")
  @@index([stale], map: "idx_health_check_state_stale")
  @@index([next_check_at], map: "idx_health_check_state_next_check")
}

model health_check_findings {
  id                BigInt                 @id @default(autoincrement())
  result_id         BigInt
  diagnosis_code_id BigInt
  status            health_finding_status  @default(open)
  severity          issue_priority         @default(medium)
  title             String
  message           String?
  evidence          Json?
  suggested_fix     Json?
  changeset_id      BigInt?
  first_seen_at     DateTime               @default(now()) @db.Timestamptz(6)
  last_seen_at      DateTime               @default(now()) @db.Timestamptz(6)
  resolved_at       DateTime?              @db.Timestamptz(6)
  changeset         changesets?            @relation(fields: [changeset_id], references: [id], onUpdate: NoAction, map: "fk_health_check_findings_changeset")
  diagnosis_code    health_diagnosis_codes @relation(fields: [diagnosis_code_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_health_check_findings_code")
  result            health_check_results   @relation(fields: [result_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_health_check_findings_result")

  @@index([result_id], map: "idx_health_check_findings_result")
  @@index([diagnosis_code_id], map: "idx_health_check_findings_code")
  @@index([status], map: "idx_health_check_findings_status")
  @@index([changeset_id], map: "idx_health_check_findings_changeset")
}

/// Remediation pipeline (runner-owned tables; Explorer reads them for UI).
/// Mirrors source-health-check-runner/migrations/0045_*.sql.
model health_remediation_runs {
  id           BigInt                          @id @default(autoincrement())
  kind         health_remediation_run_kind     @default(manual)
  status       health_remediation_run_status   @default(queued)
  scope        Json                            @default("{}")
  config       Json                            @default("{}")
  summary      Json?
  worker_id    String?
  started_at   DateTime?                       @db.Timestamptz(6)
  completed_at DateTime?                       @db.Timestamptz(6)
  error        String?
  created_at   DateTime                        @default(now()) @db.Timestamptz(6)
  updated_at   DateTime                        @default(now()) @updatedAt @db.Timestamptz(6)
  batch_jobs   health_remediation_batch_jobs[]
  targets      health_remediation_targets[]

  @@index([status], map: "idx_health_remediation_runs_status")
}

model health_remediation_targets {
  id                 BigInt                            @id @default(autoincrement())
  run_id             BigInt
  diagnosis_code_id  BigInt
  strategy           String
  execution_kind     health_remediation_execution_kind
  entity_type        String
  entity_id          BigInt
  finding_ids        BigInt[]                          @default([])
  target_fingerprint String
  source_fingerprint String?
  context            Json                              @default("{}")
  status             health_remediation_target_status  @default(pending)
  status_reason      String?
  created_at         DateTime                          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                          @default(now()) @updatedAt @db.Timestamptz(6)
  stage              Int                               @default(0)
  stage_data         Json?
  finding_id         BigInt
  proposals          health_remediation_proposals[]
  diagnosis_code     health_diagnosis_codes            @relation(fields: [diagnosis_code_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_health_remediation_targets_diag")
  run                health_remediation_runs           @relation(fields: [run_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_health_remediation_targets_run")

  @@unique([run_id, finding_id, strategy], map: "uq_health_remediation_targets_run_finding_strategy")
  @@index([run_id], map: "idx_health_remediation_targets_run")
  @@index([run_id, status], map: "idx_health_remediation_targets_status")
  @@index([strategy], map: "idx_health_remediation_targets_strategy")
  @@index([finding_id], map: "idx_health_remediation_targets_finding")
  @@index([run_id, strategy, stage], map: "idx_health_remediation_targets_stage")
}

model health_remediation_batch_jobs {
  id                 BigInt                        @id @default(autoincrement())
  run_id             BigInt
  strategy           String
  shard_index        Int
  provider           String
  provider_job_id    String?
  status             health_check_batch_job_status @default(pending)
  input_s3_uri       String?
  output_s3_uri      String?
  manifest_s3_uri    String?
  item_count         Int                           @default(0)
  real_item_count    Int                           @default(0)
  padding_item_count Int                           @default(0)
  model              String?
  prompt_version     String?
  submitted_at       DateTime?                     @db.Timestamptz(6)
  completed_at       DateTime?                     @db.Timestamptz(6)
  imported_at        DateTime?                     @db.Timestamptz(6)
  error              String?
  processed_items    Int                           @default(0)
  failed_items       Int                           @default(0)
  imported_items     Int                           @default(0)
  created_at         DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                      @default(now()) @updatedAt @db.Timestamptz(6)
  stage              Int                           @default(0)
  run                health_remediation_runs       @relation(fields: [run_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_health_remediation_batch_jobs_run")

  @@unique([run_id, strategy, shard_index, stage], map: "uq_health_remediation_batch_jobs_shard")
